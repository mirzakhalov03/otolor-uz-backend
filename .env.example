# Server
PORT=5050
NODE_ENV=development

# CORS — comma-separated allowed origins (no trailing slashes)
# In production, replace with your actual frontend domain(s)
CORS_ORIGINS=https://otolor.uz,https://www.otolor.uz,https://otolor-uz.vercel.app,http://localhost:3000,http://localhost:5173,http://localhost:5050

# MongoDB
MONGO_URI=mongodb://localhost:27017/otolor-appointments

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=dev

# Auth (single shared admin)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
ADMIN_USERNAME=otoloruzadmin
ADMIN_PASSWORD=change-me

# Clinic timezone (used for all date logic)
CLINIC_TIMEZONE=Asia/Tashkent
