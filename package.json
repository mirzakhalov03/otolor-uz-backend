{
  "name": "otolor-appointment-api",
  "version": "1.0.0",
  "description": "Appointment Management System REST API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node-dev --transpile-only src/server.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke.integration.test.ts",
    "seed:services": "ts-node-dev --transpile-only src/scripts/seed-services.ts"
  },
  "keywords": [
    "appointment",
    "api",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.14.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
